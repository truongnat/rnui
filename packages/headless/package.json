{
  "name": "@truongdq01/headless",
  "version": "1.0.2",
  "type": "module",
  "description": "Headless primitives for RNUI — logic, state, a11y. No styles.",
  "keywords": [
    "react-native",
    "headless",
    "hooks",
    "accessibility"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && bun tsc -p tsconfig.types.json && cp -r dist-types/. dist/ && rm -rf dist-types",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bunx jest --passWithNoTests",
    "test:bun": "bun test",
    "clean": "rm -rf dist dist-types"
  },
  "dependencies": {
    "@truongdq01/tokens": "^1.0.2"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-native": ">=0.83.2",
    "react-native-gesture-handler": ">=2.30.0",
    "react-native-reanimated": ">=4.2.0",
    "react-native-worklets": ">=0.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}