{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": ".",
        "declaration": true,
        "declarationMap": true,
        "composite": false,
        "emitDeclarationOnly": false,
        "noEmit": false
    },
    "references": [
        {
            "path": "../tokens"
        }
    ],
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/__tests__"
    ]
}