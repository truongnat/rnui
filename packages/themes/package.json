{
  "name": "@truongdq01/themes",
  "version": "1.0.3",
  "private": false,
  "description": "Multi-brand plugin presets for @truongdq01/ui",
  "keywords": [
    "react-native",
    "ui",
    "theme",
    "brand",
    "dark-mode"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./default": {
      "types": "./dist/brands/default.d.ts",
      "import": "./dist/brands/default.mjs",
      "require": "./dist/brands/default.js"
    },
    "./love": {
      "types": "./dist/brands/love.d.ts",
      "import": "./dist/brands/love.mjs",
      "require": "./dist/brands/love.js"
    },
    "./forest": {
      "types": "./dist/brands/forest.d.ts",
      "import": "./dist/brands/forest.mjs",
      "require": "./dist/brands/forest.js"
    },
    "./midnight": {
      "types": "./dist/brands/midnight.d.ts",
      "import": "./dist/brands/midnight.mjs",
      "require": "./dist/brands/midnight.js"
    },
    "./ocean": {
      "types": "./dist/brands/ocean.d.ts",
      "import": "./dist/brands/ocean.mjs",
      "require": "./dist/brands/ocean.js"
    },
    "./sunset": {
      "types": "./dist/brands/sunset.d.ts",
      "import": "./dist/brands/sunset.mjs",
      "require": "./dist/brands/sunset.js"
    },
    "./telegram": {
      "types": "./dist/brands/telegram.d.ts",
      "import": "./dist/brands/telegram.mjs",
      "require": "./dist/brands/telegram.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && bun tsc -p tsconfig.types.json && cp -r dist-types/. dist/ && rm -rf dist-types",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:jest": "bash ../headless/scripts/run-jest.sh --passWithNoTests",
    "clean": "rm -rf dist dist-types"
  },
  "dependencies": {
    "@truongdq01/tokens": "^1.0.3"
  },
  "peerDependencies": {
    "@truongdq01/headless": "^1.0.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
