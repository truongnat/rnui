{
  "name": "@truongnat/themes",
  "version": "1.0.0",
  "private": false,
  "description": "Multi-brand plugin presets for @truongnat/ui",
  "keywords": [
    "react-native",
    "ui",
    "theme",
    "brand",
    "dark-mode"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && bun tsc -p tsconfig.types.json && cp -r dist-types/. dist/ && rm -rf dist-types",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist dist-types"
  },
  "dependencies": {
    "@truongnat/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@truongnat/headless": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
