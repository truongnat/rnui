{
  "name": "@truongdq01/tokens",
  "version": "1.0.3",
  "description": "Design tokens for RNUI — primitive, semantic, component",
  "keywords": [
    "react-native",
    "design-tokens",
    "theme"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./primitive": {
      "types": "./dist/primitive.d.ts",
      "import": "./dist/primitive.mjs",
      "require": "./dist/primitive.js"
    },
    "./semantic": {
      "types": "./dist/semantic.d.ts",
      "import": "./dist/semantic.mjs",
      "require": "./dist/semantic.js"
    },
    "./component": {
      "types": "./dist/component.d.ts",
      "import": "./dist/component.mjs",
      "require": "./dist/component.js"
    },
    "./brand": {
      "types": "./dist/brand.d.ts",
      "import": "./dist/brand.mjs",
      "require": "./dist/brand.js"
    },
    "./motion": {
      "types": "./dist/motion.d.ts",
      "import": "./dist/motion.mjs",
      "require": "./dist/motion.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "!dist/**/chunk-*"
  ],
  "scripts": {
    "build": "tsup && bun tsc -p tsconfig.types.json && cp -r dist-types/. dist/ && rm -rf dist-types",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist dist-types"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "ts-jest": "^29.3.2",
    "jest": "^29.7.0"
  }
}
