{
  "name": "@truongdq01/ui",
  "version": "1.0.3",
  "description": "Styled components for RNUI — batteries-included, fully themeable",
  "keywords": [
    "react-native",
    "ui",
    "components",
    "design-system"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "!dist/**/*.map",
    "!dist/tsup.config.*"
  ],
  "scripts": {
    "build": "tsup && bun tsc -p tsconfig.types.json && cp -r dist-types/. dist/ && rm -rf dist-types",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:jest": "node ./scripts/run-jest.cjs --testPathPattern=\"__tests__(?!/perf)\"",
    "clean": "rm -rf dist dist-types",
    "test:perf": "node ./scripts/run-jest.cjs --testPathPattern=perf"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "^9.1.0",
    "@truongdq01/headless": "^1.0.3",
    "@truongdq01/tokens": "^1.0.3",
    "lucide-react-native": "^0.577.0",
    "react-native-svg": "^15.15.4"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-native": "^0.83.2",
    "@shopify/flash-list": "^2.0.2",
    "expo-blur": ">=14.0.0",
    "expo-linear-gradient": ">=14.0.0",
    "react-native-gesture-handler": ">=2.30.0",
    "react-native-reanimated": ">=4.2.0",
    "react-native-worklets": ">=0.7.0",
    "react-native-safe-area-context": ">=5.6.0"
  },
  "peerDependenciesMeta": {
    "@shopify/flash-list": {
      "optional": true
    },
    "expo-blur": {
      "optional": true
    },
    "expo-linear-gradient": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.73.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
