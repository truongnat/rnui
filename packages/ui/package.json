{
  "name": "@rnui/ui",
  "version": "0.0.1",
  "description": "Styled components for RNUI — batteries-included, fully themeable",
  "keywords": [
    "react-native",
    "ui",
    "components",
    "design-system"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && bun tsc -p tsconfig.types.json && cp -r dist-types/. dist/ && rm -rf dist-types",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathPattern=\"__tests__(?!/perf)\"",
    "clean": "rm -rf dist dist-types",
    "test:perf": "jest --testPathPattern=perf"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "^9.1.0",
    "@rnui/headless": "workspace:*",
    "@rnui/tokens": "workspace:*",
    "@shopify/flash-list": "^2.0.2",
    "lucide-react-native": "^0.577.0"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-native": ">=0.83.2",
    "react-native-gesture-handler": ">=2.30.0",
    "react-native-reanimated": ">=4.2.0",
    "react-native-worklets": ">=0.7.0",
    "react-native-safe-area-context": ">=5.6.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.0",
    "jest": "^29.7.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}