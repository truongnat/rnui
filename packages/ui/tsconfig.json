{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@truongdq01/tokens": [
                "../tokens/src"
            ],
            "@truongdq01/headless": [
                "../headless/src"
            ]
        },
        "skipLibCheck": true,
        "composite": false,
        "declaration": true,
        "declarationMap": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/__tests__/**/*",
        "**/*.test.ts",
        "**/*.test.tsx"
    ]
}