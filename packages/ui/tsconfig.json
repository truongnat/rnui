{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": ".",
        "paths": {
            "@rnui/tokens": [
                "../tokens/src"
            ],
            "@rnui/headless": [
                "../headless/src"
            ]
        },
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/__tests__/**/*",
        "**/*.test.ts",
        "**/*.test.tsx"
    ]
}