{
  "name": "@truongdq01/example",
  "version": "0.0.2",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:clean": "rm -rf ios/build",
    "ios:fresh": "expo prebuild --clean -p ios && expo run:ios",
    "typecheck": "tsc --noEmit",
    "e2e:ios": "detox test --configuration ios.sim.debug",
    "e2e:android": "detox test --configuration android.emu.debug",
    "e2e:build:ios": "detox build --configuration ios.sim.debug"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@truongdq01/ui": "^1.0.3",
    "babel-preset-expo": "^55.0.11",
    "expo": "~55.0.0",
    "expo-blur": "^55.0.12",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-haptics": "~55.0.8",
    "expo-router": "~55.0.0",
    "expo-system-ui": "^55.0.9",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.8.3",
    "detox": "^20.21.0",
    "jest-circus": "^29.7.0",
    "reassure": "^0.10.1"
  }
}
